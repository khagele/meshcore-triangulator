# Cloudflare Tunnel token for the cloudflared sidecar.
# Cloudflare Zero Trust → Networks → Tunnels → create a tunnel → copy the token.
TUNNEL_TOKEN=

# Optional: run a different image than the upstream default
# (e.g. your fork's build). Leave unset to use the default.
#TRIANGULATOR_IMAGE=ghcr.io/<your-username>/meshcore-triangulator:latest
